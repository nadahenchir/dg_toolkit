{
  "openapi": "3.0.0",
  "info": {
    "title": "DG Toolkit API",
    "version": "1.0.0",
    "description": "KPMG Tunisia Data Governance Maturity Assessment Toolkit"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5000/api"
    }
  ],
  "paths": {
    "/organizations": {
      "get": {
        "summary": "List all organizations",
        "tags": ["Organizations"],
        "responses": {
          "200": { "description": "List of organizations" }
        }
      },
      "post": {
        "summary": "Create a new organization",
        "tags": ["Organizations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "industry"],
                "properties": {
                  "name":                { "type": "string" },
                  "industry":            { "type": "string", "enum": ["Banking","Insurance","Telecom","Energy","Retail","Healthcare","Public Sector","Industrial","Other"] },
                  "industry_other":      { "type": "string", "description": "Required when industry is Other. Free text e.g. 'law firm'" },
                  "country":             { "type": "string" },
                  "size_band":           { "type": "string", "enum": ["SME","Large","Enterprise"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Organization created" },
          "400": { "description": "Validation error" }
        }
      }
    },

    "/organizations/{org_id}": {
      "get": {
        "summary": "Get organization by ID",
        "tags": ["Organizations"],
        "parameters": [
          { "name": "org_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Organization found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Soft delete an organization",
        "tags": ["Organizations"],
        "parameters": [
          { "name": "org_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Organization deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/consultants": {
      "get": {
        "summary": "List all consultants",
        "tags": ["Consultants"],
        "responses": {
          "200": { "description": "List of consultants" }
        }
      },
      "post": {
        "summary": "Create a new consultant",
        "tags": ["Consultants"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["full_name", "email"],
                "properties": {
                  "full_name": { "type": "string" },
                  "email":     { "type": "string" },
                  "role":      { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Consultant created" },
          "409": { "description": "Email already exists" }
        }
      }
    },

    "/consultants/{consultant_id}": {
      "get": {
        "summary": "Get consultant by ID",
        "tags": ["Consultants"],
        "parameters": [
          { "name": "consultant_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Consultant found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete a consultant",
        "tags": ["Consultants"],
        "parameters": [
          { "name": "consultant_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Consultant deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/assessments": {
      "get": {
        "summary": "List all assessments",
        "tags": ["Assessments"],
        "responses": {
          "200": { "description": "List of assessments" }
        }
      },
      "post": {
        "summary": "Create a new assessment",
        "tags": ["Assessments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["organization_id", "consultant_id"],
                "properties": {
                  "organization_id": { "type": "integer" },
                  "consultant_id":   { "type": "integer" },
                  "engagement_date": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Assessment created" },
          "404": { "description": "Organization or consultant not found" }
        }
      }
    },

    "/assessments/consultant/{consultant_id}": {
      "get": {
        "summary": "Get all assessments by consultant",
        "tags": ["Assessments"],
        "parameters": [
          { "name": "consultant_id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": {
          "200": { "description": "Assessments returned successfully" },
          "404": { "description": "Consultant not found" }
        }
      }
    },

    "/assessments/{assessment_id}": {
      "get": {
        "summary": "Get assessment by ID",
        "tags": ["Assessments"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Assessment found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Soft delete an assessment",
        "tags": ["Assessments"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Assessment deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/assessments/{assessment_id}/targets": {
      "post": {
        "summary": "Set domain targets for an assessment",
        "tags": ["Assessments"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["targets"],
                "properties": {
                  "targets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "domain_id":    { "type": "integer" },
                        "target_level": { "type": "integer", "minimum": 1, "maximum": 5 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Targets set" },
          "409": { "description": "Targets already locked" }
        }
      }
    },

    "/assessments/{assessment_id}/start": {
      "post": {
        "summary": "Lock targets and start assessment",
        "tags": ["Assessments"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Assessment started" },
          "400": { "description": "Not all targets set" },
          "409": { "description": "Already started" }
        }
      }
    },

    "/assessments/{assessment_id}/answers": {
      "get": {
        "summary": "Get all answers for an assessment",
        "tags": ["Answers"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of answers" }
        }
      }
    },

    "/assessments/{assessment_id}/answers/kpi/{kpi_id}": {
      "post": {
        "summary": "Save answers for one KPI in bulk",
        "tags": ["Answers"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "kpi_id",        "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["answers"],
                "properties": {
                  "answers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "question_id":     { "type": "integer" },
                        "selected_option": { "type": "string", "enum": ["Fully","Mostly","Partially","Slightly","Not","N.A"] }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Answers saved" },
          "400": { "description": "Validation error" },
          "409": { "description": "Assessment not in progress" }
        }
      }
    },

    "/assessments/{assessment_id}/submit": {
      "post": {
        "summary": "Submit assessment and trigger scoring pipeline",
        "tags": ["Answers"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Assessment submitted and scored" },
          "207": { "description": "Submitted but scoring failed" },
          "400": { "description": "Incomplete answers" },
          "409": { "description": "Already submitted" }
        }
      }
    },

    "/assessments/{assessment_id}/scores": {
      "get": {
        "summary": "Get scores for a submitted assessment",
        "tags": ["Scores"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 }
        ],
        "responses": {
          "200": { "description": "Scores returned successfully" },
          "404": { "description": "Assessment not found" },
          "409": { "description": "Scoring not yet complete" }
        }
      }
    },

    "/assessments/{assessment_id}/recommendations": {
      "get": {
        "summary": "Get recommendations for a complete assessment",
        "tags": ["Recommendations"],
        "parameters": [
          { "name": "assessment_id",  "in": "path",  "required": true,  "schema": { "type": "integer" }, "example": 1 },
          { "name": "domain_id",      "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "action_category","in": "query", "required": false, "schema": { "type": "string", "enum": ["Quick Win","Strategic","Fill In"] } },
          { "name": "impact",         "in": "query", "required": false, "schema": { "type": "string", "enum": ["High","Medium","Low"] } },
          { "name": "effort",         "in": "query", "required": false, "schema": { "type": "string", "enum": ["High","Medium","Low"] } },
          { "name": "maturity_level", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 5 } },
          { "name": "kpi_id",         "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "min_gap",        "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "sort_by",        "in": "query", "required": false, "schema": { "type": "string", "enum": ["priority_score","gap","maturity_level","impact","effort"], "default": "priority_score" } },
          { "name": "sort_order",     "in": "query", "required": false, "schema": { "type": "string", "enum": ["asc","desc"], "default": "desc" } }
        ],
        "responses": {
          "200": { "description": "Recommendations returned successfully" },
          "404": { "description": "Assessment not found" },
          "409": { "description": "Assessment not yet complete" }
        }
      }
    },

    "/assessments/{assessment_id}/layer2/run": {
      "post": {
        "summary": "Manually trigger Layer 2 for an assessment",
        "tags": ["Recommendations"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "force", "in": "query", "required": false, "schema": { "type": "boolean", "default": false }, "description": "Set to true to re-run and overwrite existing scores" }
        ],
        "responses": {
          "200": { "description": "Layer 2 triggered successfully" },
          "404": { "description": "Assessment not found" },
          "409": { "description": "Layer 2 already running or not ready" }
        }
      }
    },

    "/assessments/{assessment_id}/layer3/run": {
      "post": {
        "summary": "Manually trigger Layer 3 RAG for an assessment",
        "tags": ["Recommendations"],
        "parameters": [
          { "name": "assessment_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "force", "in": "query", "required": false, "schema": { "type": "boolean", "default": false }, "description": "Set to true to re-run and overwrite existing narratives" }
        ],
        "responses": {
          "200": { "description": "Layer 3 completed successfully" },
          "404": { "description": "Assessment not found" },
          "409": { "description": "Layer 2 not done, or Layer 3 already running or completed" },
          "500": { "description": "Internal server error" }
        }
      }
    },

    "/recommendations/{recommendation_id}/rate": {
      "post": {
        "summary": "Rate a recommendation post-engagement",
        "tags": ["Recommendations"],
        "parameters": [
          { "name": "recommendation_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["was_implemented", "implementation_rating"],
                "properties": {
                  "was_implemented":       { "type": "boolean" },
                  "implementation_rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "implementation_notes":  { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Rating saved" },
          "400": { "description": "Validation error" },
          "404": { "description": "Recommendation not found" }
        }
      }
    }
  }
}