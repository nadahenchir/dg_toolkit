{
  "openapi": "3.0.0",
  "info": {
    "title": "DG Toolkit API",
    "version": "1.0.0",
    "description": "KPMG Tunisia Data Governance Maturity Assessment Toolkit"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5000/api"
    }
  ],
  "paths": {
    "/organizations": {
      "get": {
        "summary": "List all organizations",
        "tags": ["Organizations"],
        "responses": {
          "200": {
            "description": "List of organizations"
          }
        }
      },
      "post": {
        "summary": "Create a new organization",
        "tags": ["Organizations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "industry"],
                "properties": {
                  "name": { "type": "string" },
                  "industry": {
                    "type": "string",
                    "enum": [
                      "Banking",
                      "Insurance",
                      "Telecom",
                      "Energy",
                      "Retail",
                      "Healthcare",
                      "Public Sector",
                      "Other"
                    ]
                  },
                  "country": { "type": "string" },
                  "size_band": {
                    "type": "string",
                    "enum": ["SME", "Large", "Enterprise"]
                  },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Organization created" },
          "400": { "description": "Validation error" }
        }
      }
    },

    "/organizations/{org_id}": {
      "get": {
        "summary": "Get organization by ID",
        "tags": ["Organizations"],
        "parameters": [
          {
            "name": "org_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Organization found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Soft delete an organization",
        "tags": ["Organizations"],
        "parameters": [
          {
            "name": "org_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Organization deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/consultants": {
      "get": {
        "summary": "List all consultants",
        "tags": ["Consultants"],
        "responses": {
          "200": {
            "description": "List of consultants"
          }
        }
      },
      "post": {
        "summary": "Create a new consultant",
        "tags": ["Consultants"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["full_name", "email"],
                "properties": {
                  "full_name": { "type": "string" },
                  "email": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Consultant created" },
          "409": { "description": "Email already exists" }
        }
      }
    },

    "/consultants/{consultant_id}": {
      "get": {
        "summary": "Get consultant by ID",
        "tags": ["Consultants"],
        "parameters": [
          {
            "name": "consultant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Consultant found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete a consultant",
        "tags": ["Consultants"],
        "parameters": [
          {
            "name": "consultant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Consultant deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/assessments": {
      "get": {
        "summary": "List all assessments",
        "tags": ["Assessments"],
        "responses": {
          "200": { "description": "List of assessments" }
        }
      },
      "post": {
        "summary": "Create a new assessment",
        "tags": ["Assessments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["organization_id", "consultant_id"],
                "properties": {
                  "organization_id": { "type": "integer" },
                  "consultant_id": { "type": "integer" },
                  "engagement_date": {
                    "type": "string",
                    "format": "date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Assessment created" },
          "404": {
            "description": "Organization or consultant not found"
          }
        }
      }
    },

    "/assessments/{assessment_id}": {
      "get": {
        "summary": "Get assessment by ID",
        "tags": ["Assessments"],
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Assessment found" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Soft delete an assessment",
        "tags": ["Assessments"],
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Assessment deleted" },
          "404": { "description": "Not found" }
        }
      }
    },

    "/assessments/{assessment_id}/targets": {
      "post": {
        "summary": "Set domain targets for an assessment",
        "tags": ["Assessments"],
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["targets"],
                "properties": {
                  "targets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "domain_id": { "type": "integer" },
                        "target_level": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 5
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Targets set" },
          "409": { "description": "Targets already locked" }
        }
      }
    },

    "/assessments/{assessment_id}/start": {
      "post": {
        "summary": "Lock targets and start assessment",
        "tags": ["Assessments"],
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Assessment started" },
          "400": { "description": "Not all targets set" },
          "409": { "description": "Already started" }
        }
      }
    }
  }
}